# ─── Stellar Network ───────────────────────────────────────────────────────────
# Which network to connect to: testnet | mainnet
NEXT_PUBLIC_NETWORK="testnet"

# Soroban RPC endpoint
NEXT_PUBLIC_RPC_URL="https://soroban-testnet.stellar.org"

# Horizon API (for balance queries)
NEXT_PUBLIC_HORIZON_URL="https://horizon-testnet.stellar.org"

# Network passphrase
NEXT_PUBLIC_NETWORK_PASSPHRASE="Test SDF Network ; September 2015"

# Block explorer base URL
NEXT_PUBLIC_EXPLORER_BASE="https://stellar.expert/explorer/testnet"

# ─── Contract ─────────────────────────────────────────────────────────────────
# Soroban Contract ID — populated automatically by deploy.mjs
# Replace CONTRACT_ADDRESS_HERE after running: npm run deploy:testnet
NEXT_PUBLIC_CONTRACT_ID="CONTRACT_ADDRESS_HERE"

# ─── Deployer (server-side only, never expose to browser) ─────────────────────
# Stellar account alias used for deployment (created by stellar CLI)
DEPLOYER_ACCOUNT="nexa-deployer"
